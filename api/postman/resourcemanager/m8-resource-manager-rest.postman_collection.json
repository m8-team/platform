{
  "info": {
    "_postman_id": "7e1585e3-8fe6-4a16-b922-3e7555081f73",
    "name": "M8 Resource Manager - REST",
    "description": "REST requests generated from the current google.api.http annotations under api/proto/m8/platform/resourcemanager/v1. Health and Organization routes are registered on the current HTTP runtime. Workspace and Service routes remain contract-only until their adapters are registered. Run folders in order to capture IDs and optimistic-lock versions automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.test(\"Status code is 2xx\", function () {",
          "    pm.expect(pm.response.code).to.be.within(200, 299);",
          "});",
          "",
          "let body;",
          "try {",
          "    body = pm.response.json();",
          "} catch (error) {",
          "    body = null;",
          "}",
          "",
          "if (body) {",
          "    const path = pm.request.url.getPath();",
          "    const resources = [",
          "        { segment: '/organizations', singular: 'organization', plural: 'organizations' },",
          "        { segment: '/workspaces', singular: 'workspace', plural: 'workspaces' },",
          "        { segment: '/services', singular: 'service', plural: 'services' }",
          "    ];",
          "",
          "    const descriptor = resources.find(function (resource) {",
          "        return path.indexOf(resource.segment) !== -1;",
          "    });",
          "",
          "    if (descriptor) {",
          "        let resource = null;",
          "        if (body.response && body.response[descriptor.singular]) {",
          "            resource = body.response[descriptor.singular];",
          "        } else if (body[descriptor.singular]) {",
          "            resource = body[descriptor.singular];",
          "        } else if (body.id) {",
          "            resource = body;",
          "        } else if (Array.isArray(body[descriptor.plural]) && body[descriptor.plural].length > 0) {",
          "            resource = body[descriptor.plural][0];",
          "        }",
          "",
          "        if (resource && resource.id) {",
          "            pm.environment.set(descriptor.singular + '_id', resource.id);",
          "        }",
          "        if (resource && resource.version !== undefined) {",
          "            pm.environment.set(descriptor.singular + '_version', String(resource.version));",
          "        }",
          "        if (body.nextPageToken !== undefined) {",
          "            pm.environment.set(descriptor.singular + '_page_token', body.nextPageToken);",
          "        }",
          "    }",
          "}"
        ]
      }
    }
  ],
