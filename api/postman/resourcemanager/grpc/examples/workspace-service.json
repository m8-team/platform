{
  "service": "m8.platform.resourcemanager.v1.WorkspaceService",
  "runtimeStatus": "contract-only; not registered in the current server",
  "methods": {
    "GetWorkspace": {
      "id": "{{workspace_id}}"
    },
    "ListWorkspaces": {
      "organizationId": "{{organization_id}}",
      "pageSize": 50,
      "pageToken": "{{workspace_page_token}}",
      "filter": "",
      "orderBy": "name",
      "showDeleted": false
    },
    "CreateWorkspace": {
      "organizationId": "{{organization_id}}",
      "workspace": {
        "name": "postman-workspace-{{$timestamp}}",
        "description": "Created by Postman over gRPC",
        "labels": {
          "m8.io/source": "postman",
          "m8.io/protocol": "grpc"
        }
      }
    },
    "UpdateWorkspace": {
      "workspace": {
        "id": "{{workspace_id}}",
        "name": "postman-workspace-updated",
        "description": "Updated by Postman over gRPC",
        "version": "{{workspace_version}}",
        "labels": {
          "m8.io/source": "postman",
          "m8.io/protocol": "grpc"
        }
      },
      "updateMask": "name,description,labels"
    },
    "DeleteWorkspace": {
      "id": "{{workspace_id}}",
      "version": "{{workspace_version}}",
      "allowMissing": false
    },
    "UndeleteWorkspace": {
      "id": "{{workspace_id}}"
    }
  }
}
