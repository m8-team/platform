{
  "service": "saas.iam.authz.v1.AuthorizationFacadeService",
  "methods": {
    "GetRole": {
      "role_id": "{{tenant_role_id}}"
    },
    "ListRoles": {
      "page_size": 50
    },
    "SetAccessBindings": {
      "request_id": "req-{{$timestamp}}",
      "resource": {
        "type": "RESOURCE_TYPE_PROJECT",
        "id": "{{analytics_project_id}}",
        "tenant_id": "{{tenant_id}}"
      },
      "desired_bindings": [
        {
          "binding_id": "bind-postman-set-{{$timestamp}}",
          "subject": {
            "type": "SUBJECT_TYPE_USER_ACCOUNT",
            "id": "{{secondary_user_id}}",
            "tenant_id": "{{tenant_id}}"
          },
          "resource": {
            "type": "RESOURCE_TYPE_PROJECT",
            "id": "{{analytics_project_id}}",
            "tenant_id": "{{tenant_id}}"
          },
          "role_id": "project-viewer",
          "reason": "postman grpc set"
        }
      ],
      "reason": "postman grpc set",
      "performed_by": "{{performed_by}}"
    },
    "UpdateAccessBindings": {
      "request_id": "req-{{$timestamp}}",
      "resource": {
        "type": "RESOURCE_TYPE_PROJECT",
        "id": "{{analytics_project_id}}",
        "tenant_id": "{{tenant_id}}"
      },
      "delta": {
        "mutations": [
          {
            "kind": "BINDING_MUTATION_KIND_ADD",
            "binding": {
              "binding_id": "bind-postman-update-{{$timestamp}}",
              "subject": {
                "type": "SUBJECT_TYPE_USER_ACCOUNT",
                "id": "{{support_user_id}}",
                "tenant_id": "{{tenant_id}}"
              },
              "resource": {
                "type": "RESOURCE_TYPE_PROJECT",
                "id": "{{analytics_project_id}}",
                "tenant_id": "{{tenant_id}}"
              },
              "role_id": "{{role_id}}",
              "reason": "postman grpc update"
            }
          }
        ]
      },
      "reason": "postman grpc update",
      "performed_by": "{{performed_by}}"
    },
    "CheckAccess": {
      "subject": {
        "type": "SUBJECT_TYPE_USER_ACCOUNT",
        "id": "{{user_id}}",
        "tenant_id": "{{tenant_id}}"
      },
      "resource": {
        "type": "RESOURCE_TYPE_TENANT",
        "id": "{{tenant_id}}",
        "tenant_id": "{{tenant_id}}"
      },
      "permission": "tenant.manage"
    },
    "BatchCheckAccess": {
      "items": [
        {
          "subject": {
            "type": "SUBJECT_TYPE_USER_ACCOUNT",
            "id": "{{user_id}}",
            "tenant_id": "{{tenant_id}}"
          },
          "resource": {
            "type": "RESOURCE_TYPE_TENANT",
            "id": "{{tenant_id}}",
            "tenant_id": "{{tenant_id}}"
          },
          "permission": "tenant.manage"
        },
        {
          "subject": {
            "type": "SUBJECT_TYPE_USER_ACCOUNT",
            "id": "{{secondary_user_id}}",
            "tenant_id": "{{tenant_id}}"
          },
          "resource": {
            "type": "RESOURCE_TYPE_PROJECT",
            "id": "{{analytics_project_id}}",
            "tenant_id": "{{tenant_id}}"
          },
          "permission": "project.read"
        }
      ]
    },
    "ExplainAccess": {
      "subject": {
        "type": "SUBJECT_TYPE_USER_ACCOUNT",
        "id": "{{secondary_user_id}}",
        "tenant_id": "{{tenant_id}}"
      },
      "resource": {
        "type": "RESOURCE_TYPE_PROJECT",
        "id": "{{analytics_project_id}}",
        "tenant_id": "{{tenant_id}}"
      },
      "permission": "project.read"
    }
  }
}
