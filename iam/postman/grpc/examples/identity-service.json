{
  "service": "saas.iam.identity.v1.IdentityService",
  "methods": {
    "GetUser": {
      "user_id": "{{user_id}}"
    },
    "ListUsers": {
      "tenant_id": "{{tenant_id}}",
      "page_size": 50
    },
    "CreateUser": {
      "request_id": "req-{{$timestamp}}",
      "tenant_id": "{{tenant_id}}",
      "primary_email": "grpc+{{$timestamp}}@example.com",
      "display_name": "gRPC User {{$timestamp}}",
      "labels": {
        "source": "postman-grpc"
      },
      "performed_by": "{{performed_by}}"
    },
    "UpdateUser": {
      "user": {
        "user_id": "{{secondary_user_id}}",
        "tenant_id": "{{tenant_id}}",
        "primary_email": "grpc-analyst@example.com",
        "display_name": "Demo Analyst gRPC",
        "state": "USER_STATE_ACTIVE",
        "labels": {
          "persona": "analyst",
          "updated_via": "postman-grpc"
        }
      },
      "update_mask": {
        "paths": [
          "primary_email",
          "display_name",
          "labels"
        ]
      },
      "request_id": "req-{{$timestamp}}",
      "performed_by": "{{performed_by}}"
    },
    "DisableUser": {
      "user_id": "{{secondary_user_id}}",
      "reason": "postman grpc disable",
      "request_id": "req-{{$timestamp}}",
      "performed_by": "{{performed_by}}"
    },
    "GetTenant": {
      "tenant_id": "{{tenant_id}}"
    },
    "ListTenants": {
      "page_size": 50
    },
    "CreateTenant": {
      "request_id": "req-{{$timestamp}}",
      "tenant_id": "tenant-postman-{{$timestamp}}",
      "display_name": "Postman Tenant {{$timestamp}}",
      "external_ref": "crm-postman-{{$timestamp}}",
      "labels": {
        "source": "postman-grpc"
      },
      "performed_by": "{{performed_by}}"
    },
    "UpdateTenant": {
      "tenant": {
        "tenant_id": "{{tenant_id}}",
        "display_name": "Demo Tenant Updated",
        "external_ref": "crm-demo-001",
        "labels": {
          "tier": "gold",
          "edited_by": "postman-grpc"
        }
      },
      "update_mask": {
        "paths": [
          "display_name",
          "labels"
        ]
      },
      "request_id": "req-{{$timestamp}}",
      "performed_by": "{{performed_by}}"
    },
    "ListMemberships": {
      "tenant_id": "{{tenant_id}}",
      "page_size": 50
    },
    "CreateMembership": {
      "request_id": "req-{{$timestamp}}",
      "membership_id": "mship-postman-{{$timestamp}}",
      "tenant_id": "{{tenant_id}}",
      "user_id": "{{support_user_id}}",
      "role_ids": [
        "project-viewer"
      ],
      "performed_by": "{{performed_by}}"
    },
    "DeleteMembership": {
      "membership_id": "{{membership_id}}",
      "request_id": "req-{{$timestamp}}",
      "reason": "postman grpc cleanup",
      "performed_by": "{{performed_by}}"
    },
    "GetGroup": {
      "group_id": "{{group_id}}"
    },
    "ListGroups": {
      "tenant_id": "{{tenant_id}}",
      "page_size": 50
    },
    "CreateGroup": {
      "request_id": "req-{{$timestamp}}",
      "group_id": "grp-postman-{{$timestamp}}",
      "tenant_id": "{{tenant_id}}",
      "display_name": "Postman Group {{$timestamp}}",
      "description": "Created from Postman gRPC",
      "labels": {
        "source": "postman-grpc"
      },
      "performed_by": "{{performed_by}}"
    },
    "UpdateGroup": {
      "group": {
        "group_id": "{{group_id}}",
        "tenant_id": "{{tenant_id}}",
        "display_name": "Operations Updated",
        "description": "Updated from Postman gRPC",
        "labels": {
          "team": "ops",
          "edited_by": "postman-grpc"
        }
      },
      "update_mask": {
        "paths": [
          "display_name",
          "description",
          "labels"
        ]
      },
      "request_id": "req-{{$timestamp}}",
      "performed_by": "{{performed_by}}"
    },
    "DeleteGroup": {
      "group_id": "{{group_id}}",
      "request_id": "req-{{$timestamp}}",
      "reason": "postman grpc delete",
      "performed_by": "{{performed_by}}"
    },
    "AddGroupMember": {
      "request_id": "req-{{$timestamp}}",
      "group_id": "{{group_id}}",
      "subject_id": "{{secondary_user_id}}",
      "subject_type": "user_account",
      "performed_by": "{{performed_by}}"
    },
    "RemoveGroupMember": {
      "request_id": "req-{{$timestamp}}",
      "group_id": "{{group_id}}",
      "subject_id": "{{secondary_user_id}}",
      "subject_type": "user_account",
      "reason": "postman grpc cleanup",
      "performed_by": "{{performed_by}}"
    },
    "GetServiceAccount": {
      "service_account_id": "{{service_account_id}}"
    },
    "ListServiceAccounts": {
      "tenant_id": "{{tenant_id}}",
      "page_size": 50
    },
    "CreateServiceAccount": {
      "request_id": "req-{{$timestamp}}",
      "service_account_id": "sa-postman-{{$timestamp}}",
      "tenant_id": "{{tenant_id}}",
      "display_name": "Postman Automation",
      "description": "Created from Postman gRPC",
      "performed_by": "{{performed_by}}"
    },
    "UpdateServiceAccount": {
      "service_account": {
        "service_account_id": "{{service_account_id}}",
        "tenant_id": "{{tenant_id}}",
        "display_name": "Demo Bot Updated",
        "description": "Updated from Postman gRPC",
        "disabled": false
      },
      "update_mask": {
        "paths": [
          "display_name",
          "description"
        ]
      },
      "request_id": "req-{{$timestamp}}",
      "performed_by": "{{performed_by}}"
    },
    "DeleteServiceAccount": {
      "service_account_id": "{{service_account_id}}",
      "request_id": "req-{{$timestamp}}",
      "reason": "postman grpc delete",
      "performed_by": "{{performed_by}}"
    }
  }
}
