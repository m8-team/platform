IAM_SERVICE_NAME=m8-platform-iam
IAM_ENVIRONMENT=local
IAM_DEVELOPMENT=true

IAM_GRPC_ADDRESS=:8080
IAM_HTTP_ADDRESS=:8082
IAM_OPENAPI_DIR=gen/openapi

IAM_YDB_DSN=grpc://127.0.0.1:2136/local
IAM_YDB_DATABASE=/local

IAM_REDIS_ADDRESS=127.0.0.1:6379
IAM_REDIS_PASSWORD=
IAM_REDIS_DB=0
IAM_REDIS_DEFAULT_TTL=5m
IAM_REDIS_CHECK_ACCESS_TTL=30s
IAM_POLICY_VERSION=local-v1

IAM_KEYCLOAK_BASE_URL=http://127.0.0.1:8081
IAM_KEYCLOAK_REALM=m8
IAM_KEYCLOAK_CLIENT_ID=admin-cli
IAM_KEYCLOAK_CLIENT_SECRET=unused-in-local-dev

IAM_SPICEDB_ENDPOINT=127.0.0.1:50051
IAM_SPICEDB_TOKEN=dev-spicedb-key
IAM_SPICEDB_SCHEMA_PATH=docs/spicedb/schema.zed
IAM_SPICEDB_PRESHARED_KEY=dev-spicedb-key
IAM_SPICEDB_CONSISTENCY=at_least_as_fresh

IAM_TEMPORAL_ENABLED=true
IAM_TEMPORAL_ADDRESS=127.0.0.1:7233
IAM_TEMPORAL_NAMESPACE=default
IAM_TEMPORAL_TASK_QUEUE=iam-task-queue
